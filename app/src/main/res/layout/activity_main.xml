<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@android:color/black">

    <!-- Main View Container -->
    <FrameLayout
        android:id="@+id/main_view_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_controls"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <FrameLayout
            android:id="@+id/camera_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:scaleType="fitCenter" />

            <com.zhuo.c1cam.OverlayView
                android:id="@+id/overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>
    </FrameLayout>

    <!-- Picture-in-Picture View Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/pip_view_container"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls"
        app:layout_constraintStart_toStartOf="parent"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">
        
        <!-- We use an inner frame so we can swap children easily without dealing with CardView specifics -->
        <FrameLayout
            android:id="@+id/pip_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/preview_rectified"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />
                
        </FrameLayout>

        <!-- Dedicated touch interceptor to prevent children from stealing clicks -->
        <View
            android:id="@+id/pip_touch_blocker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent" />
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@android:color/white"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#80000000"
            android:padding="4dp" />

    </androidx.cardview.widget.CardView>

    <!-- Top Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#B3000000"
        android:padding="12dp">

        <Button
            android:id="@+id/settings_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@android:color/white"
            app:icon="@android:drawable/ic_menu_preferences"
            app:iconTint="@android:color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ToggleButton
            android:id="@+id/edit_mode_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOn="Done"
            android:textOff="Edit"
            android:checked="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#4DFFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#B3000000"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@+id/sliders_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/capture_button"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="EV"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/ev_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="-2.0"
                    android:valueTo="2.0"
                    android:value="0.0"
                    android:stepSize="1.0"
                    app:thumbColor="@android:color/white"
                    app:trackColorActive="@android:color/white"
                    app:trackColorInactive="#4DFFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="AF"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/focus_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:value="0.0"
                    app:thumbColor="@android:color/white"
                    app:trackColorActive="@android:color/white"
                    app:trackColorInactive="#4DFFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/capture_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@android:drawable/ic_menu_camera"
            app:tint="@android:color/black"
            app:backgroundTint="@android:color/white"
            app:fabSize="normal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Capture" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
