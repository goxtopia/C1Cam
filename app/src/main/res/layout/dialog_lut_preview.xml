<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/lut_preview_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a LUT to preview instantly"
        android:textColor="@color/cam_text_secondary"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_preview_frame"
        android:padding="6dp">

        <ImageView
            android:id="@+id/lut_preview_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="LUT Preview"
            android:scaleType="centerCrop" />

        <ProgressBar
            android:id="@+id/lut_preview_progress"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/lut_preview_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Current: None"
        android:textColor="@color/cam_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/lut_list"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="8dp"
        android:choiceMode="singleChoice"
        android:divider="@android:color/transparent"
        android:dividerHeight="6dp" />

</LinearLayout>
