<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="@color/cam_accent_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/cam_accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#38FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/cam_accent" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#24FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/cam_panel_stroke" />
        </shape>
    </item>
</selector>
